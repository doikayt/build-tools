{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "npmScope": "datalackey",
  "projects": {},
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "test": {
      "cache": true,
      "inputs": ["default", "^default"]
    },
    "ci": {
      "dependsOn": ["build", "test", "lint"],
      "cache": false
    }
  },
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": []
  }
}
