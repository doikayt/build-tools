{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "rootDir": "src",
    "outDir": "dist",

    "strict": false,

    "allowJs": true,
    "checkJs": false,

    "noEmitOnError": true,
    "declaration": false,
    "sourceMap": false
  },
  "include": ["src"]
}