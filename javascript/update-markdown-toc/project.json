{
  "name": "@datalackey/update-markdown-toc",
  "sourceRoot": "update-markdown-toc/src",
  "projectType": "library",
  "targets": {
    "build": {
      "command": "cd update-markdown-toc && rm -rf dist && npm run build",
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "command": "cd update-markdown-toc && bash scripts/run-all-tests.sh",
      "dependsOn": ["build", "@datalackey/tooling-core:build"]
    },
    "lint": {
      "command": "npx eslint 'update-markdown-toc/src/**/*.ts'",
      "cwd": "{workspaceRoot}",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{workspaceRoot}/tsconfig.eslint.json",
        "{workspaceRoot}/.eslintrc*",
        "{workspaceRoot}/eslint.config*"
      ],
      "outputs": [],
      "dependsOn": ["@datalackey/tooling-core:build"]
    },
    "check-prod-types": {
      "//": [
        "--noEmit: run the full type checker but write nothing to disk.",
        "This is the CI gate that catches what the IDE should have caught locally.",
        "We do NOT use --noCheck here — that would defeat the purpose.",
        "dependsOn ^build ensures dependency .d.ts files exist before we typecheck."
      ],
      "command": "cd update-markdown-toc && npx tsc -p tsconfig.json --noEmit",
      "dependsOn": ["^build"]
    },
    "check-types": {
      "//": [
        "Aggregates prod and test type checking for this package.",
        "check-prod-types covers src/ (published code).",
        "check-test-types will be added when tsconfig.test.json is created."
      ],
      "dependsOn": ["check-prod-types"]
    }
  }
}
