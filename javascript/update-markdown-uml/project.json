{
  "name": "@datalackey/update-markdown-uml",
  "sourceRoot": "update-markdown-uml/src",
  "projectType": "library",
  "targets": {
    "build": {
      "command": "cd update-markdown-uml && rm -rf dist && npm run build",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["@datalackey/tooling-core:build"]
    },
    "test": {
      "command": "npx vitest run --config {projectRoot}/vitest.config.ts",
      "dependsOn": ["build"]
    },
    "lint": {
      "command": "npx eslint 'update-markdown-uml/src/**/*.ts'",
      "cwd": "{workspaceRoot}",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{workspaceRoot}/tsconfig.eslint.json",
        "{workspaceRoot}/.eslintrc*",
        "{workspaceRoot}/eslint.config*"
      ],
      "outputs": [],
      "dependsOn": ["@datalackey/tooling-core:build"]
    },
    "typecheck": {
      "//": [
        "--noEmit: run the full type checker but write nothing to disk.",
        "This is the CI gate that catches what the IDE should have caught locally.",
        "We do NOT use --noCheck here — that would defeat the purpose.",
        "dependsOn ^build ensures dependency .d.ts files exist before we typecheck."
      ],
      "command": "cd update-markdown-uml && npx tsc -p tsconfig.json --noEmit",
      "dependsOn": ["^build"]
    }
  }
}
