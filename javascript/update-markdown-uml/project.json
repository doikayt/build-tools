{
  "name": "@datalackey/update-markdown-uml",
  "sourceRoot": "update-markdown-uml/src",
  "projectType": "library",
  "targets": {
    "build": {
      "command": "cd update-markdown-uml && rm -rf dist && tsc -p tsconfig.json",
      "outputs": ["{projectRoot}/dist"],
      "dependsOn": ["@datalackey/tooling-core:build"]
    },
    "test": {
      "command": "npx vitest run --config {projectRoot}/vitest.config.ts",
      "dependsOn": ["build"]
    },
    "lint": {
      "command": "npx eslint 'update-markdown-uml/src/**/*.ts'",
      "cwd": "{workspaceRoot}",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{workspaceRoot}/tsconfig.eslint.json",
        "{workspaceRoot}/.eslintrc*",
        "{workspaceRoot}/eslint.config*"
      ],
      "outputs": [],
      "dependsOn": ["@datalackey/tooling-core:build"]
    },
    "check-prod-types": {
      "//": [
        "--noEmit: run the full type checker but write nothing to disk.",
        "This is the CI gate that catches what the IDE should have caught locally.",
        "We do NOT use --noCheck here — that would defeat the purpose.",
        "dependsOn ^build ensures dependency .d.ts files exist before we typecheck."
      ],
      "command": "cd update-markdown-uml && npx tsc -p tsconfig.json --noEmit",
      "dependsOn": ["^build"]
    },
    "check-test-types": {
      "//": [
        "--noEmit: type-check test files without emitting.",
        "Uses tsconfig.test.json which includes tests/ in addition to src/.",
        "Kept separate from check-prod-types so test-only type errors",
        "do not affect the production build path."
      ],
      "command": "cd update-markdown-uml && npx tsc -p tsconfig.test.json --noEmit",
      "dependsOn": ["^build"]
    },
    "e2e": {
      "command": "npx vitest run --config {projectRoot}/vitest.e2e.config.ts",
      "dependsOn": ["build", "@datalackey/tooling-core:build"]
    },
    "check-types": {
      "//": [
        "Aggregates prod and test type checking for this package.",
        "check-prod-types covers src/ (published code).",
        "check-test-types covers tests/ (not published but still type-checked)."
      ],
      "dependsOn": ["check-prod-types", "check-test-types"]
    }
  }
}
