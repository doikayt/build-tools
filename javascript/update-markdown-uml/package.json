{
  "name": "@doikayt/update-markdown-uml",
  "version": "1.4.17",
  "description": "Generates and validates UML class and component diagrams for TypeScript source trees, injecting them into Markdown documentation files",
  "license": "MIT",
  "type": "module",
  "private": false,
  "bin": {
    "update-markdown-uml": "./bin/update-markdown-uml.js"
  },
  "files": [
    "bin/",
    "dist/",
    "README.md"
  ],
  "engines": {
    "node": ">=22"
  },
  "keywords": [
    "uml",
    "typescript",
    "mermaid",
    "documentation",
    "class-diagram",
    "component-diagram",
    "ci",
    "automation"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/doikayt/build-tools.git",
    "directory": "javascript/update-markdown-uml"
  },
  "bugs": {
    "url": "https://github.com/doikayt/build-tools/issues"
  },
  "homepage": "https://github.com/doikayt/build-tools/tree/main/javascript/update-markdown-uml",
  "scripts": {
    "prepack": "npx nx build @doikayt/update-markdown-uml 1>&2"
  },
  "dependencies": {
    "@doikayt/tooling-core": "^1.4.17",
    "ts-morph": "^24.0.0",
    "micromatch": "^4.0.0",
    "github-slugger": "^2.0.0"
  },
  "devDependencies": {
    "@types/node": "^18.16.0",
    "@types/micromatch": "^4.0.9",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  }
}
