{
  "name": "@datalackey/tooling-core",
  "sourceRoot": "tooling-core/src",
  "projectType": "library",
  "targets": {
    "build": {
      "command": "npm run build",
      "cwd": "tooling-core",
      "outputs": ["{projectRoot}/dist"]
    },
    "test": {
      "command": "npm test",
      "cwd": "tooling-core"
    },
    "lint": {
      "command": "tsc -p tsconfig.json --noEmit",
      "cwd": "tooling-core"
    }
  }
}
