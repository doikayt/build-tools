{
  "name": "build-tools",
  "private": true,
  "workspaces": [
    "*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "ci": "npx nx run build-tools-workspace:ci --skip-nx-cache",
    "post-publish": "sleep 60 && VERSION=$(node -p \"require('./autogen-markdown-doc/package.json').version\") && cd autogen-markdown-doc && PUBLISHED_VERSION=$VERSION npx vitest run --config vitest.integration.config.ts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@doikayt/typescript-build-config": "^0.1.7",
    "@doikayt/update-markdown-toc": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "eslint": "^9.39.4",
    "nx": "22.5.4",
    "vitest": "^4.0.18"
  }
}
