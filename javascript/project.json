{
  "name": "build-tools-workspace",
  "//": [
    "This is the project config for build-tools-workspace --the workspace-level orchestration project.",
    "",
    "It owns targets that are specific to this workspace as a whole (ci, check-toc,",
    "check-lint, check-format, format, update-toc).",
    "The main purpose of this config file is enforcement of ",
    "formatting, type safety, code layout and other conventions. These enforcement checks run invariably ",
    "in CI, but also can (and should) be run locally, so as to avoid CI/build regressions",
    "",
    "For the rule on what belongs here vs nx.json targetDefaults, see nx.json '//'."
  ],
  "projectType": "library",
  "implicitDependencies": [
    "@datalackey/tooling-core",
    "@datalackey/update-markdown-toc",
    "@datalackey/nx-graph-to-mermaid",
    "@datalackey/update-markdown-uml"
  ],
  "targets": {
    "update-toc": {
      "command": "node update-markdown-toc/bin/update-markdown-toc.js --recursive .",
      "cwd": "{workspaceRoot}"
    },
    "check-toc": {
      "command": "node update-markdown-toc/bin/update-markdown-toc.js --check --recursive   . -e node_modules,test,test-fixtures,tests -l 5000",
      "cwd": "{workspaceRoot}",
      "dependsOn": ["^build"]
    },
    "check-lint": {
      "cwd": "{workspaceRoot}",
      "dependsOn": [
        "@datalackey/tooling-core:lint",
        "@datalackey/update-markdown-toc:lint",
        "@datalackey/nx-graph-to-mermaid:lint",
        "@datalackey/update-markdown-uml:lint"
      ]
    },
    "check-format": {
      "command": "npx prettier --check .",
      "cwd": "{workspaceRoot}"
    },
    "format": {
      "command": "npx prettier --write .",
      "cwd": "{workspaceRoot}"
    },
    "ci": {
      "dependsOn": [
        "^build",
        "^test",
        "build-tools-workspace:check-toc",
        "build-tools-workspace:check-lint",
        "build-tools-workspace:check-format",
        "build-tools-workspace:check-types"
      ]
    },
    "check-types": {
      "//": [
        "Aggregates per-package typecheck targets.",
        "Runs tsc --noEmit across all packages — CI gate only, not part of local build loop.",
        "Philosophy: developers fix type errors in the IDE (red = do not commit).",
        "This target exists to catch the lazy commit. See per-package typecheck targets."
      ],
      "dependsOn": [
        "@datalackey/tooling-core:typecheck",
        "@datalackey/update-markdown-toc:typecheck",
        "@datalackey/nx-graph-to-mermaid:typecheck",
        "@datalackey/update-markdown-uml:typecheck"
      ]
    }
  }
}
