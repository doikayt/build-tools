{
  "name": "build-tools-workspace",
  "projectType": "library",
  "implicitDependencies": [
    "@datalackey/tooling-core",
    "@datalackey/update-markdown-toc",
    "@datalackey/nx-graph-to-mermaid",
    "@datalackey/update-markdown-uml"
  ],
  "targets": {
    "update:toc": {
      "command": "node update-markdown-toc/bin/update-markdown-toc.js --recursive .",
      "cwd": "{workspaceRoot}"
    },
    "check:toc": {
      "command": "node update-markdown-toc/bin/update-markdown-toc.js --check --recursive .",
      "cwd": "{workspaceRoot}"
    },
    "lint": {
      "command": "npx eslint 'tooling-core/src/**/*.ts' 'update-markdown-toc/src/**/*.ts' 'nx-graph-to-mermaid/src/**/*.ts' 'update-markdown-uml/src/**/*.ts'",
      "cwd": "{workspaceRoot}",
      "dependsOn": ["^build"]
    }
  }
}