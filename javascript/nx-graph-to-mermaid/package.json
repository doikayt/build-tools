{
  "name": "@datalackey/nx-graph-to-mermaid",
  "executors": "./executors.json",
  "version": "1.2.1",
  "private": false,
  "description": "Auto-generates a Mermaid task flow diagram from an NX `project.json` file — with optional CI drift detection and Markdown injection support.",
  "main": "dist/index.js",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/datalackey/build-tools.git",
    "directory": "javascript/nx-graph-to-mermaid"
  },
  "bugs": {
    "url": "https://github.com/datalackey/build-tools/issues"
  },
  "files": [
    "dist",
    "README.md",
    "executors.json",
    "executor-bridge.cjs",
    "package.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/datalackey/build-tools/tree/main/javascript/nx-graph-to-mermaid",
  "keywords": [
    "nx",
    "javascript",
    "node",
    "typescript",
    "mermaid",
    "graph",
    "task-graph",
    "build",
    "automation",
    "documentation",
    "ci"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc && npm run copy-schemas",
    "test": "vitest run",
    "copy-schemas": "mkdir -p dist/executors/generate && cp src/executors/generate/schema.json dist/executors/generate/schema.json"
  },
  "devDependencies": {
    "@datalackey/update-markdown-toc": "1.2.1",
    "@types/node": "^18.16.0",
    "typescript": "^5.4.0",
    "vitest": "^1.0.0"
  },
  "dependencies": {
    "@datalackey/tooling-core": "*"
  }
}
