{
  "$schema": "http://json-schema.org/schema",
  "title": "Mermaid Task Graph Executor",
  "type": "object",
  "properties": {
    "projectJsonPath": {
      "type": "string"
    },
    "mode": {
      "type": "string",
      "enum": ["generate", "check", "inject"],
      "default": "generate"
    },
    "generatedMermaidPath": {
      "type": "string"
    },
    "markdownPath": {
      "type": "string"
    }
  },
  "required": ["projectJsonPath"]
}
