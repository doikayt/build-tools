{
  "$schema": "https://json.schemastore.org/nx-plugin",
  "executors": {
    "generate": {
      "implementation": "./dist/executors/generate/executor.js",
      "schema": "./dist/executors/generate/schema.json",
      "description": "Generate Mermaid diagram from project.json"
    },
    "check": {
      "implementation": "./dist/executors/generate/executor.js",
      "schema": "./dist/executors/generate/schema.json",
      "description": "Check Mermaid drift"
    },
    "inject": {
      "implementation": "./dist/executors/generate/executor.js",
      "schema": "./dist/executors/generate/schema.json",
