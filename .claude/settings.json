{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "cd /workspace/javascript && npx nx run build-tools-workspace:update-all && git -C /workspace add -u",
            "timeout": 120,
            "statusMessage": "Running update-all before commit..."
          }
        ]
      }
    ]
  }
}
